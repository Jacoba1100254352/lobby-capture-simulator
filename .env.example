USASPENDING_TRANSACTION_DOWNLOAD_POLL_ATTEMPTS=60
USASPENDING_TRANSACTION_DOWNLOAD_POLL_SECONDS=5
SAM_CONTRACT_AWARDS_SOURCE_NATIVE=0
# Optional downloaded SAM.gov Contract Awards export. These take precedence over the keyed live API.
# Use a representative Contract Awards CSV/JSON/ZIP export from SAM.gov DataBank or Contract Data search.
# Emailed async extract links from SAM.gov may be pasted as-is when they contain
# api_key=REPLACE_WITH_API_KEY; the local SAM_API_KEY is substituted at runtime.
# SAM.gov emailed download links are short-lived. Prefer:
#   make sam-contract-awards-record-export-link < sam-email.txt
# or:
#   python3 scripts/record-sam-export-link.py --url 'https://api.sam.gov/...'
# The helper normalizes api_key=REPLACE_WITH_API_KEY, records expiration
# metadata and its timestamp source, clears any stale LIVE_CSV override, and
# redacts the token in output. If several emails are pasted together, the
# helper chooses the latest dated URL, or the last URL when Date headers are
# absent. Timestamped links that have already expired are rejected by default;
# request a fresh export instead of recording an overnight link. If TIME_SOURCE
# is recorded_at_fallback, use the link only when the email was just generated.
SAM_CONTRACT_AWARDS_LIVE_CSV=
SAM_CONTRACT_AWARDS_LIVE_URL=
SAM_CONTRACT_AWARDS_LIVE_URL_GENERATED_AT=
SAM_CONTRACT_AWARDS_LIVE_URL_EXPIRES_AT=
SAM_CONTRACT_AWARDS_LIVE_URL_VALID_MINUTES=60
SAM_CONTRACT_AWARDS_LIVE_URL_RECORDED_AT=
SAM_CONTRACT_AWARDS_LIVE_URL_TIME_SOURCE=
SAM_CONTRACT_AWARDS_EXPORT_MIN_ROWS=5000
SAM_CONTRACT_AWARDS_EXPORT_MIN_AWARDS=1000
SAM_CONTRACT_AWARDS_EXPORT_MIN_AGENCIES=6
SAM_CONTRACT_AWARDS_EXPORT_MIN_DATE_SPAN_DAYS=270
SAM_CONTRACT_AWARDS_EXPORT_MIN_PIID_SHARE=0.95
SAM_CONTRACT_AWARDS_EXPORT_MIN_UEI_SHARE=0.50
SAM_CONTRACT_AWARDS_EXPORT_MIN_ACTION_DATE_SHARE=0.80
SAM_CONTRACT_AWARDS_EXPORT_MIN_COMPETITION_SHARE=0.25
# Keep this at 0 for publication refreshes. Set to 1 only for an explicitly
# documented diagnostic refresh that should proceed despite nonblocking audit warnings.
SAM_CONTRACT_AWARDS_ALLOW_DIAGNOSTIC_PROMOTION=0
SAM_CONTRACT_AWARDS_FISCAL_YEAR=2024
SAM_CONTRACT_AWARDS_AGENCIES="Environmental Protection Agency,Department of Energy,Department of the Interior,Department of Agriculture,Department of Transportation,Department of Defense,Department of Health and Human Services,Department of Veterans Affairs,Department of Homeland Security,National Aeronautics and Space Administration,General Services Administration,Department of Commerce"
SAM_CONTRACT_AWARDS_PIID_SUBTIER_CODES=
SAM_CONTRACT_AWARDS_PIID_SUBTIER_NAMES=
SAM_CONTRACT_AWARDS_DEPARTMENT_CODES=
SAM_CONTRACT_AWARDS_PAGE_SIZE=100
SAM_CONTRACT_AWARDS_MAX_PAGES=1
SAM_CONTRACT_AWARDS_FETCH_RETRIES=1
SAM_CONTRACT_AWARDS_FETCH_TIMEOUT_SECONDS=45
SAM_CONTRACT_AWARDS_FETCH_HARD_TIMEOUT_SECONDS=75
SAM_CONTRACT_AWARDS_INCLUDE_SECTIONS=contractId,coreData,awardDetails,awardeeData
SAM_CONTRACT_AWARDS_EXTRACT_MODE=0
SAM_CONTRACT_AWARDS_EXTRACT_FORMAT=json
# SAM.gov requires emailId together with format for asynchronous extracts; Yes sends the download notice to the SAM account email.
SAM_CONTRACT_AWARDS_EXTRACT_EMAIL_ID=Yes
SAM_CONTRACT_AWARDS_EXTRACT_POLL_ATTEMPTS=8
SAM_CONTRACT_AWARDS_EXTRACT_POLL_SECONDS=10
SAM_CONTRACT_AWARDS_OFFSET_START=0
# Optional comma-separated page-index strata for non-adjacent SAM.gov Contract Awards slices.
# With MAX_PAGES=1 and PAGE_SIZE=100, this samples approximate row positions 0, 1000, and 5000 per filter.
# These page-index starts are ignored when SAM_CONTRACT_AWARDS_EXTRACT_MODE=1.
SAM_CONTRACT_AWARDS_OFFSET_STARTS=0,10,50
SAM_CONTRACT_AWARDS_DATE_FROM=
SAM_CONTRACT_AWARDS_DATE_TO=
SAM_CONTRACT_AWARDS_LAST_MODIFIED_FROM=2023-10-01
SAM_CONTRACT_AWARDS_LAST_MODIFIED_TO=2024-09-30
SAM_CONTRACT_AWARDS_MODIFICATION_NUMBER=
SAM_CONTRACT_AWARDS_PREFLIGHT_AGENCY="Environmental Protection Agency"
SAM_CONTRACT_AWARDS_PREFLIGHT_PAGE_SIZE=1
SAM_CONTRACT_AWARDS_PREFLIGHT_RETRIES=1
SAM_CONTRACT_AWARDS_PREFLIGHT_TIMEOUT_SECONDS=20
SAM_CONTRACT_AWARDS_PREFLIGHT_HARD_TIMEOUT_SECONDS=30
SAM_CONTRACT_AWARDS_PREFLIGHT_EXTRACT_MODE=0
# SAM.gov public Exclusions API preflight. This checks access/quota for the
# exclusion-overlay acquisition path only; it does not promote source rows.
SAM_EXCLUSIONS_API_BASE=https://api.sam.gov/entity-information/v4
SAM_EXCLUSIONS_QUERY=
SAM_EXCLUSIONS_PAGE=0
SAM_EXCLUSIONS_PAGE_SIZE=10
SAM_EXCLUSIONS_TIMEOUT_SECONDS=20
SAM_EXCLUSIONS_USER_AGENT="lobby-capture-simulator/1.0 (+https://github.com/Jacoba1100254352/lobby-capture-simulator)"
# Guarded refresh wrapper mode: auto prefers a configured export, otherwise preflight-gated extract mode.
SAM_PROCUREMENT_REFRESH_MODE=auto
# GAO Legal Products RSS feed. This no-key operational preflight discovers
