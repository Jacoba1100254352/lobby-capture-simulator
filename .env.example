USASPENDING_PROCUREMENT_ACTIONS_TRANSACTION_SORT_SPECS="Mod:asc;Transaction Amount:desc;Action Date:asc"
# Separate no-agency-filtered pull used for national-volume procurement concentration diagnostics only.
