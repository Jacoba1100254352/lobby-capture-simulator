# Optional DOI archive draft workflow. The default target is Zenodo sandbox and
# never publishes a record. Use production only for the final human-reviewed DOI
# draft after the release assets and final read-through are ready.
ZENODO_API_BASE=https://sandbox.zenodo.org/api
ZENODO_USE_PRODUCTION=0
ZENODO_ACCESS_TOKEN=
# Accepted token aliases, checked in this order for the selected API target:
# sandbox: ZENODO_SANDBOX_TOKEN, then generic aliases below.
# production: ZENODO_PRODUCTION_TOKEN, then generic aliases below.
ZENODO_SANDBOX_TOKEN=
ZENODO_PRODUCTION_TOKEN=
ZENODO_API_TOKEN=
ZENODO_TOKEN=
ZENODO_DEPOSIT_ID=
# After Zenodo/OSF reserves or mints a DOI, set ARCHIVE_DOI and optionally
# ARCHIVE_URL, then run make record-doi-archive to update tracked metadata.
ARCHIVE_DOI=
ARCHIVE_URL=
