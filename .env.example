# Copy this file to .env and fill in the private values locally.
# .env is intentionally ignored by git.

# Official credential links:
# LDA: https://lda.gov/api/register/
# FEC / Regulations.gov: https://api.data.gov/signup/
# OpenSecrets / MyOpenSecrets: https://www.opensecrets.org/api/admin/index.php

LDA_API_KEY=
FEC_API_KEY=
REGULATIONS_API_KEY=
OPENSECRETS_API_KEY=

LDA_API_BASE=https://lda.gov/api/v1
FEC_API_BASE=https://api.open.fec.gov/v1
REGULATIONS_API_BASE=https://api.regulations.gov/v4
FEDERAL_REGISTER_API_BASE=https://www.federalregister.gov/api/v1
USASPENDING_API_BASE=https://api.usaspending.gov/api/v2

SOURCE_RAW_DIR=data/raw/source-payloads/2024-env
SOURCE_FETCH_RETRIES=3
SOURCE_FETCH_BACKOFF_SECONDS=1

LDA_YEAR=2024
LDA_ISSUE_CODE=ENV
LDA_PAGE_SIZE=100
LDA_MAX_PAGES=25
DEFAULT_ISSUE_DOMAIN=energy

FEC_CYCLE=2024
FEC_PAGE_SIZE=100

REGULATORY_AGENCY=EPA
REGULATORY_SEARCH_TERM="Environmental Protection Agency"
REGULATORY_DATE_FROM=2024-01-01
REGULATORY_DATE_TO=2024-12-31
REGULATORY_PAGE_SIZE=100
FEDERAL_REGISTER_TYPE=PRORULE

USASPENDING_FISCAL_YEAR=2024
USASPENDING_AGENCY="Environmental Protection Agency"
USASPENDING_DATE_FROM=2023-10-01
USASPENDING_DATE_TO=2024-09-30
USASPENDING_PAGE_SIZE=100
USASPENDING_MAX_PAGES=2
USASPENDING_AWARD_TYPE_CODES=A,B,C,D

REVOLVING_DOOR_LIVE_CSV=
REVOLVING_DOOR_LIVE_URL=
