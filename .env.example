# Copy this file to .env and fill in the private values locally.
# .env is intentionally ignored by git.

# Official credential links:
# LDA: https://lda.gov/api/register/
# FEC / Regulations.gov: https://api.data.gov/signup/
# OpenSecrets / MyOpenSecrets: https://www.opensecrets.org/api/admin/index.php
# FollowTheMoney / National Institute on Money in Politics: configure if using state campaign-finance overlays.
# SAM.gov public APIs: https://open.gsa.gov/api/
# ProPublica Nonprofit Explorer: https://projects.propublica.org/nonprofits/api
# LegiStorm API/account access: https://www.legistorm.com/api.html
# NYC Campaign Finance Board data library (no key): https://nyccfb.info/follow-the-money/data-library
# IRS EO BMF extracts (no key): https://www.irs.gov/charities-non-profits/exempt-organizations-business-master-file-extract-eo-bmf
# IRS 527 political organization bulk downloads (no key, large files): https://www.irs.gov/charities-non-profits/political-organizations/political-organization-filing-and-disclosure

LDA_API_KEY=
FEC_API_KEY=
REGULATIONS_API_KEY=
OPENSECRETS_API_KEY=
